{
  "tests": [
    {
      "name": "Get public places list",
      "method": "GET",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Reject POST without admin token",
      "method": "POST",
      "path": "/",
      "body": {"name": "Test"},
      "expectedStatus": 403
    },
    {
      "name": "Create support ticket",
      "method": "POST",
      "path": "/?type=support",
      "body": {"name": "Тест", "message": "Тестовое обращение"},
      "expectedStatus": 201
    },
    {
      "name": "Get messages for non-existent ticket returns 404",
      "method": "GET",
      "path": "/?type=support&ticket_id=999999",
      "expectedStatus": 404
    }
  ]
}